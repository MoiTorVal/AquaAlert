# Copy to .env and fill in real values. Never commit .env.
# All values are read by backend/config.py (Settings) unless noted.

# ── Security ───────────────────────────────────────────────────────────────
# HS256 signing key for JWTs. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (Postgres + PostGIS) ──────────────────────────────────────────
# Option A — single URL (Railway, Render, Heroku all expose this):
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# Railway exposes postgres:// — the app normalises the scheme automatically.
#
# Option B — discrete vars (local dev default):
DB_USER=aquaalert
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aquaalert

# ── External APIs ──────────────────────────────────────────────────────────
# OpenET (daily ET per field polygon). Optional — ET features disabled if unset.
OPENET_API_KEY=your-openet-key
# Spatial CIMIS (near-real-time CA reference ETo). Optional — bridges OpenET's
# ~5-7 day lag with provisional readings; gap-fill is off if unset.
# Key: https://et.water.ca.gov
CIMIS_APP_KEY=your-cimis-key
# Twilio SMS alerts. Optional — all SMS features off unless all four are set.
# SMS_WEBHOOK_URL must match the inbound URL in the Twilio console VERBATIM
# (the request signature is computed over it).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567
SMS_WEBHOOK_URL=https://api.example.com/sms/webhook

# ── Frontend / CORS ────────────────────────────────────────────────────────
# Base URL the browser uses to reach the API (read by the Next.js frontend).
# In production: set to your Railway backend URL, e.g. https://aquaalert-backend.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Comma-separated? No — set as a JSON list, e.g. ["https://app.example.com"].
ALLOWED_ORIGINS=["http://localhost:3000"]
# Cookie security. Cross-domain deploys (Railway backend + Vercel frontend)
# require SameSite=None. SameSite=None *requires* Secure=true.
#   local dev:   COOKIE_SAMESITE=lax, SECURE_COOKIE=false
#   production:  COOKIE_SAMESITE=none, SECURE_COOKIE=true
COOKIE_SAMESITE=lax
SECURE_COOKIE=false
# Formspree form ID for the public contact form (read by the Next.js
# frontend — set in frontend/.env.local, not here).
# NEXT_PUBLIC_FORMSPREE_ID=your-formspree-id

# ── Scheduler (APScheduler daily jobs) ─────────────────────────────────────
# Enable on exactly ONE single-worker process — no cross-process lock,
# N workers would run N duplicate jobs and burn the OpenET quota.
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=America/Los_Angeles
# Sentinel-2 NDVI ingestion (Earth Search + COG window reads). Optional.
SENTINEL_ENABLED=false
