# Copy to .env and fill in real values. Never commit .env.
# All values are read by backend/config.py (Settings) unless noted.

# ── Security ───────────────────────────────────────────────────────────────
# HS256 signing key for JWTs. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (Postgres + PostGIS) ──────────────────────────────────────────
DB_USER=aquaalert
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aquaalert

# ── External APIs ──────────────────────────────────────────────────────────
# OpenWeatherMap (legacy weather service). Required.
OPENWEATHER_API_KEY=your-openweather-key
# OpenET (daily ET per field polygon). Optional — ET features disabled if unset.
OPENET_API_KEY=your-openet-key
# Spatial CIMIS (near-real-time CA reference ET). Optional — bridges OpenET's
# ~5-7 day lag with provisional readings; gap-fill is off if unset.
# Key: https://et.water.ca.gov
CIMIS_APP_KEY=your-cimis-key

# ── Frontend / CORS ────────────────────────────────────────────────────────
# Base URL the browser uses to reach the API (read by the Next.js frontend).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Comma-separated? No — set as a JSON list, e.g. ["https://app.example.com"].
ALLOWED_ORIGINS=["http://localhost:3000"]
# Auth cookie is Secure (HTTPS-only) by default. Set false ONLY for local
# HTTP development — production must leave this unset or true.
SECURE_COOKIE=false
# Formspree form ID for the public contact form (read by the Next.js
# frontend — set in frontend/.env.local, not here).
# NEXT_PUBLIC_FORMSPREE_ID=your-formspree-id

# ── Scheduler (APScheduler daily jobs) ─────────────────────────────────────
# Enable on exactly ONE single-worker process — no cross-process lock,
# N workers would run N duplicate jobs and burn the OpenET quota.
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=America/Los_Angeles
